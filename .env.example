# =============================================================================
# .env.example — Copy to .env and fill in your credentials
# NEVER commit .env to version control
# =============================================================================

# --- App ---
APP_ENV=development           # development | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-256-bit-secret

# --- LLM: Groq (Llama 3) ---
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192   # llama3-8b-8192 for faster/cheaper

# --- LLM: Google Gemini ---
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash # gemini-1.5-pro for more capable

# --- LLM Routing Strategy ---
# "groq" | "gemini" | "fallback"  (fallback tries groq first, then gemini)
LLM_PROVIDER=fallback


# --- Whisper (Local STT) ---
# tiny | base | small | medium | large-v3  (larger = slower but more accurate)
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu             # cpu | cuda (if you have GPU in Docker)
WHISPER_MODEL_DIR=/app/data/whisper_models

# --- ChromaDB ---
CHROMA_HOST=localhost           # Overridden to "chromadb" inside Docker
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=faq_knowledge_base

# --- SQLite ---
SQLITE_PATH=/app/data/sqlite/chatbot.db

# --- Monitoring: LangSmith ---
# Get key at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=chatbot-prod

# --- Monitoring: Langfuse (alternative) ---
# Get keys at: https://cloud.langfuse.com/
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

